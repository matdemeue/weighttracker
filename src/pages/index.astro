---
import Layout from '../layouts/Layout.astro';
import { db } from '../lib/db';

interface Row {
  id: string;
  date: string;
  weight: number | null;
  fat_pct: number | null;
  fat_kg: number | null;
  vvm: number | null;
  water_kg: number | null;
  water_pct: number | null;
  visceral_fat: number | null;
}

const measurements = db
  .prepare('SELECT * FROM measurements ORDER BY date ASC')
  .all() as Row[];

const jsonData = JSON.stringify(measurements);
---

<Layout title="Gewichtstracker">
  <!-- server-rendered data for client scripts -->
  <script type="application/json" id="__data" set:html={jsonData}></script>

  <div class="app">
    <header>
      <div class="header-inner">
        <button id="toggleForm" class="btn-primary">+ Meting toevoegen</button>
      </div>
    </header>

    <!-- Form panel -->
    <div id="formPanel" class="form-panel hidden">
      <div class="form-card">
        <h2>Nieuwe meting</h2>
        <form id="measurementForm">
          <div class="form-grid">
            <div class="field">
              <label for="date">Datum</label>
              <input type="date" id="date" name="date" required />
            </div>
            <div class="field">
              <label for="weight">Lichaamsgewicht (kg)</label>
              <input type="number" id="weight" name="weight" step="0.1" min="0" placeholder="bijv. 82.5" required />
            </div>
            <div class="field">
              <label for="fatPct">Vet (%)</label>
              <input type="number" id="fatPct" name="fatPct" step="0.1" min="0" max="100" placeholder="bijv. 18.5" />
            </div>
            <div class="field">
              <label for="fatKg">Vet (kg)</label>
              <input type="number" id="fatKg" name="fatKg" step="0.1" min="0" placeholder="bijv. 15.2" />
            </div>
            <div class="field">
              <label for="vvm">VVM (kg)</label>
              <input type="number" id="vvm" name="vvm" step="0.1" min="0" placeholder="bijv. 67.3" />
            </div>
            <div class="field">
              <label for="waterKg">Vocht (kg)</label>
              <input type="number" id="waterKg" name="waterKg" step="0.1" min="0" placeholder="bijv. 49.2" />
            </div>
            <div class="field">
              <label for="waterPct">Vocht (%)</label>
              <input type="number" id="waterPct" name="waterPct" step="0.1" min="0" max="100" placeholder="bijv. 59.8" />
            </div>
            <div class="field">
              <label for="visceralFat">Visceraal vet</label>
              <input type="number" id="visceralFat" name="visceralFat" step="1" min="1" max="60" placeholder="bijv. 12" />
            </div>
          </div>
          <div class="form-actions">
            <button type="button" id="cancelForm" class="btn-ghost">Annuleren</button>
            <button type="submit" class="btn-primary" id="submitBtn">Opslaan</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Empty state -->
    <div id="emptyState" class={measurements.length === 0 ? 'empty-state' : 'empty-state hidden'}>
      <div class="empty-icon">📊</div>
      <h2>Nog geen metingen</h2>
      <p>Voeg je eerste meting toe om te beginnen.</p>
      <button id="emptyAddBtn" class="btn-primary">+ Eerste meting toevoegen</button>
    </div>

    <!-- Dashboard -->
    <div id="dashboard" class={measurements.length > 0 ? 'dashboard' : 'dashboard hidden'}>
      <!-- Stats bar -->
      <section id="statsBar" class="stats-bar"></section>

      <!-- Charts -->
      <section class="charts-grid">
        <div class="chart-card chart-wide">
          <h3>Lichaamsgewicht <span class="unit">kg</span></h3>
          <canvas id="chartWeight"></canvas>
        </div>
        <div class="chart-card chart-wide">
          <h3>Vet <span class="unit">%</span></h3>
          <canvas id="chartFatPct"></canvas>
        </div>
        <div class="chart-card chart-wide">
          <h3>Vet <span class="unit">kg</span></h3>
          <canvas id="chartFatKg"></canvas>
        </div>
        <div class="chart-card chart-wide">
          <h3>VVM <span class="unit">kg</span></h3>
          <canvas id="chartVvm"></canvas>
        </div>
        <div class="chart-card chart-wide">
          <h3>Vocht <span class="unit">%</span></h3>
          <canvas id="chartWaterPct"></canvas>
        </div>
        <div class="chart-card chart-wide">
          <h3>Vocht <span class="unit">kg</span></h3>
          <canvas id="chartWaterKg"></canvas>
        </div>
        <div class="chart-card chart-wide">
          <h3>Visceraal vet</h3>
          <canvas id="chartVisceral"></canvas>
        </div>
      </section>

    </div>
  </div>
</Layout>

<style>
  .app {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 16px 60px;
  }

  header {
    padding: 16px 0 20px;
    display: flex;
    justify-content: flex-end;
  }

  .header-inner {
    display: flex;
    justify-content: flex-end;
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 8px 18px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity .15s;
  }
  .btn-primary:hover { opacity: .85; }
  .btn-primary:disabled { opacity: .5; cursor: not-allowed; }

  .btn-ghost {
    background: transparent;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 8px 18px;
    font-weight: 600;
    cursor: pointer;
    transition: color .15s, border-color .15s;
  }
  .btn-ghost:hover { color: var(--text); border-color: var(--muted); }

  /* Form */
  .form-panel { margin-bottom: 28px; }
  .form-panel.hidden { display: none; }

  .form-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px 28px;
    box-shadow: 0 1px 4px rgba(0,0,0,.06);
  }
  .form-card h2 { font-size: 1rem; font-weight: 700; margin-bottom: 20px; color: var(--text); }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: 16px;
    margin-bottom: 20px;
  }

  .field { display: flex; flex-direction: column; gap: 5px; }
  .field label {
    font-size: .75rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: .04em;
  }
  .field input {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    padding: 8px 11px;
    outline: none;
    transition: border-color .15s, box-shadow .15s;
  }
  .field input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(99,102,241,.1);
  }
  .field input::placeholder { color: #cbd5e1; }

  .form-actions { display: flex; gap: 10px; justify-content: flex-end; }

  /* Empty state */
  .empty-state {
    text-align: center;
    padding: 80px 20px;
  }
  .empty-state.hidden { display: none; }
  .empty-icon { font-size: 3.5rem; margin-bottom: 14px; }
  .empty-state h2 { font-size: 1.3rem; margin-bottom: 6px; }
  .empty-state p { color: var(--muted); margin-bottom: 22px; }

  /* Dashboard */
  .dashboard.hidden { display: none; }

  /* Stats bar */
  .stats-bar {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(155px, 1fr));
    gap: 12px;
    margin-bottom: 24px;
  }

  /* Charts */
  .charts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-bottom: 28px;
  }

  .chart-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 18px 20px;
    box-shadow: 0 1px 3px rgba(0,0,0,.05);
  }

  .chart-wide { grid-column: 1 / -1; }

  .chart-card h3 {
    font-size: .78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .05em;
    color: var(--muted);
    margin-bottom: 14px;
  }
  .unit { font-weight: 400; text-transform: none; letter-spacing: 0; }

  canvas { max-height: 210px; }

  @media (max-width: 640px) {
    .charts-grid { grid-template-columns: 1fr; }
    .chart-wide { grid-column: 1; }
    .form-grid { grid-template-columns: 1fr 1fr; }
    .form-card { padding: 20px 16px; }
  }

  @media (max-width: 480px) {
    .form-grid { grid-template-columns: 1fr; }
    .form-actions { flex-direction: column-reverse; }
    .form-actions button { width: 100%; padding: 12px; }
  }
</style>

<style is:global>
  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 18px;
    box-shadow: 0 1px 3px rgba(0,0,0,.05);
  }
  .stat-label {
    font-size: .72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .05em;
    color: var(--muted);
    margin-bottom: 3px;
  }
  .stat-value {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
    display: flex;
    align-items: baseline;
    gap: 7px;
  }
  .delta {
    font-size: .75rem;
    font-weight: 600;
    padding: 1px 7px;
    border-radius: 20px;
  }
  .delta.neg { background: rgba(22,163,74,.12); color: #16a34a; }
  .delta.pos { background: rgba(239,68,68,.1);  color: #ef4444; }
  .delta.neutral { background: #f1f5f9; color: var(--muted); }
</style>

<script>
  import {
    Chart,
    LineController, LineElement, PointElement,
    LinearScale, CategoryScale,
    Filler, Tooltip,
  } from 'chart.js';

  Chart.register(LineController, LineElement, PointElement, LinearScale, CategoryScale, Filler, Tooltip);

  interface Row {
    id: string;
    date: string;
    weight: number | null;
    fat_pct: number | null;
    fat_kg: number | null;
    vvm: number | null;
    water_kg: number | null;
    water_pct: number | null;
    visceral_fat: number | null;
  }

  const initialData: Row[] = JSON.parse(
    document.getElementById('__data')!.textContent!
  );

  const chartInstances: Record<string, Chart> = {};

  const CHART_DEFS = [
    { id: 'chartWeight',   key: 'weight'      as keyof Row, color: '#6366f1', label: 'Gewicht (kg)' },
    { id: 'chartFatPct',   key: 'fat_pct'     as keyof Row, color: '#f43f5e', label: 'Vet (%)' },
    { id: 'chartFatKg',    key: 'fat_kg'      as keyof Row, color: '#f97316', label: 'Vet (kg)' },
    { id: 'chartVvm',      key: 'vvm'         as keyof Row, color: '#22c55e', label: 'VVM (kg)' },
    { id: 'chartWaterPct', key: 'water_pct'   as keyof Row, color: '#0ea5e9', label: 'Vocht (%)' },
    { id: 'chartWaterKg',  key: 'water_kg'    as keyof Row, color: '#06b6d4', label: 'Vocht (kg)' },
    { id: 'chartVisceral', key: 'visceral_fat'as keyof Row, color: '#a855f7', label: 'Visceraal vet' },
  ];

  function fmtDate(d: string) {
    const [y, m, day] = d.split('-');
    return `${day}/${m}/${y}`;
  }

  function fmt(v: number | null, dec = 1) {
    return v != null ? v.toFixed(dec) : null;
  }

  function buildChart(canvasId: string, labels: string[], values: (number | null)[], color: string, label: string) {
    const canvas = document.getElementById(canvasId) as HTMLCanvasElement | null;
    if (!canvas) return;

    if (chartInstances[canvasId]) {
      chartInstances[canvasId].data.labels = labels;
      (chartInstances[canvasId].data.datasets[0] as any).data = values;
      chartInstances[canvasId].update();
      return;
    }

    chartInstances[canvasId] = new Chart(canvas, {
      type: 'line',
      data: {
        labels,
        datasets: [{
          label,
          data: values,
          borderColor: color,
          backgroundColor: color + '18',
          fill: true,
          tension: 0.35,
          pointRadius: 4,
          pointHoverRadius: 6,
          pointBackgroundColor: color,
          borderWidth: 2,
          spanGaps: true,
        }],
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#ffffff',
            borderColor: '#e2e8f0',
            borderWidth: 1,
            titleColor: '#1e293b',
            bodyColor: '#64748b',
            padding: 10,
          },
        },
        scales: {
          x: {
            ticks: { color: '#94a3b8', font: { size: 11 } },
            grid: { color: '#f1f5f9' },
          },
          y: {
            ticks: { color: '#94a3b8', font: { size: 11 } },
            grid: { color: '#f1f5f9' },
          },
        },
      },
    });
  }

  function renderCharts(data: Row[]) {
    const labels = data.map(r => fmtDate(r.date));
    for (const def of CHART_DEFS) {
      buildChart(def.id, labels, data.map(r => r[def.key] as number | null), def.color, def.label);
    }
  }

  function renderStats(data: Row[]) {
    const bar = document.getElementById('statsBar')!;
    if (!data.length) { bar.innerHTML = ''; return; }

    const last  = data[data.length - 1];
    const first = data.length > 1 ? data[0] : null;

    const d = <T extends number>(a: T | null, b: T | null) =>
      a != null && b != null ? a - b : null;

    const items = [
      { label: 'Huidig gewicht', value: (fmt(last.weight)      ?? '—') + ' kg', delta: d(last.weight,       first?.weight       ?? null) },
      { label: 'Vet (kg)',       value: (fmt(last.fat_kg)      ?? '—') + ' kg', delta: d(last.fat_kg,       first?.fat_kg       ?? null) },
      { label: 'Vet (%)',        value: (fmt(last.fat_pct)     ?? '—') + ' %',  delta: d(last.fat_pct,      first?.fat_pct      ?? null) },
      { label: 'VVM',            value: (fmt(last.vvm)         ?? '—') + ' kg', delta: null },
      { label: 'Vocht (kg)',     value: (fmt(last.water_kg)    ?? '—') + ' kg', delta: null },
      { label: 'Visceraal vet',  value:  fmt(last.visceral_fat, 0) ?? '—',      delta: d(last.visceral_fat, first?.visceral_fat ?? null) },
    ];

    bar.innerHTML = items.map(({ label, value, delta }) => {
      let deltaHtml = '';
      if (delta != null) {
        const cls = delta < 0 ? 'neg' : delta > 0 ? 'pos' : 'neutral';
        deltaHtml = `<span class="delta ${cls}">${delta > 0 ? '+' : ''}${delta.toFixed(1)}</span>`;
      }
      return `<div class="stat-card"><div class="stat-label">${label}</div><div class="stat-value">${value}${deltaHtml}</div></div>`;
    }).join('');
  }

  function showDashboard(data: Row[]) {
    renderStats(data);
    renderCharts(data);
  }

  // Initial render
  if (initialData.length > 0) showDashboard(initialData);

  // Form toggle
  const formPanel  = document.getElementById('formPanel')!;
  const toggleBtn  = document.getElementById('toggleForm')!;
  const cancelBtn  = document.getElementById('cancelForm')!;
  const emptyBtn   = document.getElementById('emptyAddBtn')!;

  function openForm() {
    formPanel.classList.remove('hidden');
    toggleBtn.textContent = '✕ Sluiten';
    const dateInput = document.getElementById('date') as HTMLInputElement;
    if (!dateInput.value) dateInput.value = new Date().toISOString().split('T')[0];
  }

  function closeForm() {
    formPanel.classList.add('hidden');
    toggleBtn.textContent = '+ Meting toevoegen';
  }

  toggleBtn.addEventListener('click', () =>
    formPanel.classList.contains('hidden') ? openForm() : closeForm()
  );
  cancelBtn.addEventListener('click', closeForm);
  emptyBtn?.addEventListener('click', openForm);

  // Form submit
  const form      = document.getElementById('measurementForm') as HTMLFormElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Bezig…';

    const fd = new FormData(form);
    const num = (k: string) => { const v = fd.get(k); return v !== '' && v != null ? parseFloat(v as string) : null; };

    await fetch('/api/measurements', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        date:        fd.get('date'),
        weight:      num('weight'),
        fatPct:      num('fatPct'),
        fatKg:       num('fatKg'),
        vvm:         num('vvm'),
        waterKg:     num('waterKg'),
        waterPct:    num('waterPct'),
        visceralFat: num('visceralFat'),
      }),
    });

    window.location.reload();
  });
</script>
