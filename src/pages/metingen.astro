---
import Layout from '../layouts/Layout.astro';
import { db } from '../lib/db';

interface Row {
  id: string;
  date: string;
  weight: number | null;
  fat_pct: number | null;
  fat_kg: number | null;
  vvm: number | null;
  water_kg: number | null;
  water_pct: number | null;
  visceral_fat: number | null;
}

const measurements = db
  .prepare('SELECT * FROM measurements ORDER BY date ASC')
  .all() as Row[];

const jsonData = JSON.stringify(measurements);
---

<Layout title="Metingen — Gewichtstracker">
  <script type="application/json" id="__data" set:html={jsonData}></script>

  <div class="app">
    <header>
      <div class="header-inner">
        <button id="toggleForm" class="btn-primary">+ Meting toevoegen</button>
      </div>
    </header>

    <!-- Form panel -->
    <div id="formPanel" class="form-panel hidden">
      <div class="form-card">
        <h2>Nieuwe meting</h2>
        <form id="measurementForm">
          <div class="form-grid">
            <div class="field">
              <label for="date">Datum</label>
              <input type="date" id="date" name="date" required />
            </div>
            <div class="field">
              <label for="weight">Lichaamsgewicht (kg)</label>
              <input type="number" id="weight" name="weight" step="0.1" min="0" placeholder="bijv. 82.5" required />
            </div>
            <div class="field">
              <label for="fatPct">Vet (%)</label>
              <input type="number" id="fatPct" name="fatPct" step="0.1" min="0" max="100" placeholder="bijv. 18.5" />
            </div>
            <div class="field">
              <label for="fatKg">Vet (kg)</label>
              <input type="number" id="fatKg" name="fatKg" step="0.1" min="0" placeholder="bijv. 15.2" />
            </div>
            <div class="field">
              <label for="vvm">VVM (kg)</label>
              <input type="number" id="vvm" name="vvm" step="0.1" min="0" placeholder="bijv. 67.3" />
            </div>
            <div class="field">
              <label for="waterKg">Vocht (kg)</label>
              <input type="number" id="waterKg" name="waterKg" step="0.1" min="0" placeholder="bijv. 49.2" />
            </div>
            <div class="field">
              <label for="waterPct">Vocht (%)</label>
              <input type="number" id="waterPct" name="waterPct" step="0.1" min="0" max="100" placeholder="bijv. 59.8" />
            </div>
            <div class="field">
              <label for="visceralFat">Visceraal vet</label>
              <input type="number" id="visceralFat" name="visceralFat" step="1" min="1" max="60" placeholder="bijv. 12" />
            </div>
          </div>
          <div class="form-actions">
            <button type="button" id="cancelForm" class="btn-ghost">Annuleren</button>
            <button type="submit" class="btn-primary" id="submitBtn">Opslaan</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Empty state -->
    <div id="emptyState" class={measurements.length === 0 ? 'empty-state' : 'empty-state hidden'}>
      <div class="empty-icon">📊</div>
      <h2>Nog geen metingen</h2>
      <p>Voeg je eerste meting toe om te beginnen.</p>
      <button id="emptyAddBtn" class="btn-primary">+ Eerste meting toevoegen</button>
    </div>

    <!-- Table -->
    <div id="dashboard" class={measurements.length > 0 ? 'dashboard' : 'dashboard hidden'}>
      <div class="table-wrap">
        <table id="dataTable">
          <thead>
            <tr>
              <th>Datum</th>
              <th>Gewicht (kg)</th>
              <th>Vet (%)</th>
              <th>Vet (kg)</th>
              <th>VVM (kg)</th>
              <th>Vocht (kg)</th>
              <th>Vocht (%)</th>
              <th>Visceraal vet</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="tableBody"></tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>

<style>
  .app {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 16px 60px;
  }

  header {
    padding: 16px 0 20px;
    display: flex;
    justify-content: flex-end;
  }

  .header-inner {
    display: flex;
    justify-content: flex-end;
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 8px 18px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity .15s;
  }
  .btn-primary:hover { opacity: .85; }
  .btn-primary:disabled { opacity: .5; cursor: not-allowed; }

  .btn-ghost {
    background: transparent;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 8px 18px;
    font-weight: 600;
    cursor: pointer;
    transition: color .15s, border-color .15s;
  }
  .btn-ghost:hover { color: var(--text); border-color: var(--muted); }

  .form-panel { margin-bottom: 28px; }
  .form-panel.hidden { display: none; }

  .form-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px 28px;
    box-shadow: 0 1px 4px rgba(0,0,0,.06);
  }
  .form-card h2 { font-size: 1rem; font-weight: 700; margin-bottom: 20px; color: var(--text); }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: 16px;
    margin-bottom: 20px;
  }

  .field { display: flex; flex-direction: column; gap: 5px; }
  .field label {
    font-size: .75rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: .04em;
  }
  .field input {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    padding: 8px 11px;
    outline: none;
    transition: border-color .15s, box-shadow .15s;
  }
  .field input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(99,102,241,.1);
  }
  .field input::placeholder { color: #cbd5e1; }

  .form-actions { display: flex; gap: 10px; justify-content: flex-end; }

  .empty-state {
    text-align: center;
    padding: 80px 20px;
  }
  .empty-state.hidden { display: none; }
  .empty-icon { font-size: 3.5rem; margin-bottom: 14px; }
  .empty-state h2 { font-size: 1.3rem; margin-bottom: 6px; }
  .empty-state p { color: var(--muted); margin-bottom: 22px; }

  .dashboard.hidden { display: none; }

  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: 0 1px 3px rgba(0,0,0,.05);
  }

  @media (max-width: 640px) {
    .form-card { padding: 20px 16px; }
    .form-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 480px) {
    .form-grid { grid-template-columns: 1fr; }
    .form-actions { flex-direction: column-reverse; }
    .form-actions button { width: 100%; padding: 12px; }
  }
</style>

<style is:global>
  /* Table — global because tbody rows are injected via JS innerHTML */
  #dataTable {
    width: 100%;
    border-collapse: collapse;
    white-space: nowrap;
  }

  #dataTable thead tr {
    background: var(--surface2);
    border-bottom: 2px solid var(--border);
  }

  #dataTable th,
  #dataTable td {
    padding: 14px 18px;
    text-align: right;
  }

  #dataTable th {
    font-weight: 700;
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--muted);
  }

  #dataTable th:first-child,
  #dataTable td:first-child { text-align: left; }

  #dataTable th:last-child,
  #dataTable td:last-child {
    width: 48px;
    padding: 0 12px;
    text-align: center;
  }

  #dataTable td {
    font-size: .875rem;
    font-variant-numeric: tabular-nums;
    color: var(--text);
  }

  #dataTable td:first-child { font-weight: 600; }

  #dataTable tbody tr { border-bottom: 1px solid var(--border); transition: background .12s; }
  #dataTable tbody tr:last-child { border-bottom: none; }
  #dataTable tbody tr:nth-child(even) { background: #fafbfc; }
  #dataTable tbody tr:hover { background: #eef2ff; }

  #dataTable td.null-val { color: #c8d0db; font-size: .8rem; }

  .delete-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    background: none;
    border: 1px solid transparent;
    cursor: pointer;
    color: #c8d0db;
    font-size: .85rem;
    border-radius: 6px;
    transition: color .15s, background .15s, border-color .15s;
  }
  .delete-btn:hover {
    color: var(--accent2);
    background: rgba(239,68,68,.07);
    border-color: rgba(239,68,68,.2);
  }
</style>

<script>
  interface Row {
    id: string;
    date: string;
    weight: number | null;
    fat_pct: number | null;
    fat_kg: number | null;
    vvm: number | null;
    water_kg: number | null;
    water_pct: number | null;
    visceral_fat: number | null;
  }

  const initialData: Row[] = JSON.parse(
    document.getElementById('__data')!.textContent!
  );

  function fmtDate(d: string) {
    const [y, m, day] = d.split('-');
    return `${day}/${m}/${y}`;
  }

  function fmt(v: number | null, dec = 1) {
    return v != null ? v.toFixed(dec) : null;
  }

  function cell(v: number | null, dec = 1) {
    const val = fmt(v, dec);
    return val != null
      ? `<td>${val}</td>`
      : `<td class="null-val">—</td>`;
  }

  function renderTable(data: Row[]) {
    const tbody = document.getElementById('tableBody')!;
    const sorted = [...data].sort((a, b) => b.date.localeCompare(a.date));
    tbody.innerHTML = sorted.map(r => `
      <tr>
        <td>${fmtDate(r.date)}</td>
        ${cell(r.weight)}
        ${cell(r.fat_pct)}
        ${cell(r.fat_kg)}
        ${cell(r.vvm)}
        ${cell(r.water_kg)}
        ${cell(r.water_pct)}
        ${cell(r.visceral_fat, 0)}
        <td><button class="delete-btn" data-id="${r.id}" title="Verwijderen">✕</button></td>
      </tr>
    `).join('');

    tbody.querySelectorAll<HTMLButtonElement>('.delete-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('Meting verwijderen?')) return;
        const res = await fetch(`/api/measurements/${btn.dataset.id}`, { method: 'POST' });
        if (res.ok) {
          window.location.reload();
        } else {
          alert(`Verwijderen mislukt (${res.status})`);
        }
      });
    });
  }

  if (initialData.length > 0) renderTable(initialData);

  // Form toggle
  const formPanel = document.getElementById('formPanel')!;
  const toggleBtn = document.getElementById('toggleForm')!;
  const cancelBtn = document.getElementById('cancelForm')!;
  const emptyBtn  = document.getElementById('emptyAddBtn')!;

  function openForm() {
    formPanel.classList.remove('hidden');
    toggleBtn.textContent = '✕ Sluiten';
    const dateInput = document.getElementById('date') as HTMLInputElement;
    if (!dateInput.value) dateInput.value = new Date().toISOString().split('T')[0];
  }

  function closeForm() {
    formPanel.classList.add('hidden');
    toggleBtn.textContent = '+ Meting toevoegen';
  }

  toggleBtn.addEventListener('click', () =>
    formPanel.classList.contains('hidden') ? openForm() : closeForm()
  );
  cancelBtn.addEventListener('click', closeForm);
  emptyBtn?.addEventListener('click', openForm);

  // Form submit
  const form      = document.getElementById('measurementForm') as HTMLFormElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Bezig…';

    const fd = new FormData(form);
    const num = (k: string) => { const v = fd.get(k); return v !== '' && v != null ? parseFloat(v as string) : null; };

    await fetch('/api/measurements', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        date:        fd.get('date'),
        weight:      num('weight'),
        fatPct:      num('fatPct'),
        fatKg:       num('fatKg'),
        vvm:         num('vvm'),
        waterKg:     num('waterKg'),
        waterPct:    num('waterPct'),
        visceralFat: num('visceralFat'),
      }),
    });

    window.location.reload();
  });
</script>
